{
    "name": "@slfomin/pwa-laravel",
    "version": "0.1.0",
    "description": "Vite plugin and client helpers for slfomin/pwa-laravel",
    "keywords": [
        "laravel",
        "pwa",
        "vite",
        "service-worker",
        "inertia",
        "workbox"
    ],
    "homepage": "https://github.com/slfomin/pwa-laravel#readme",
    "repository": {
        "type": "git",
        "url": "https://github.com/slfomin/pwa-laravel.git"
    },
    "bugs": {
        "url": "https://github.com/slfomin/pwa-laravel/issues"
    },
    "license": "MIT",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./vue": {
            "types": "./dist/vue.d.ts",
            "import": "./dist/vue.js"
        },
        "./react": {
            "types": "./dist/react.d.ts",
            "import": "./dist/react.js"
        },
        "./svelte": {
            "types": "./dist/svelte.d.ts",
            "import": "./dist/svelte.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "prepare": "tsup"
    },
    "peerDependencies": {
        "@inertiajs/vite": "^3.0",
        "vite": "^6.0 || ^7.0 || ^8.0",
        "vite-plugin-pwa": "^1.0"
    },
    "peerDependenciesMeta": {
        "@inertiajs/vite": {
            "optional": true
        },
        "@inertiajs/vue3": {
            "optional": true
        },
        "@inertiajs/react": {
            "optional": true
        },
        "@inertiajs/svelte": {
            "optional": true
        },
        "svelte": {
            "optional": true
        }
    },
    "devDependencies": {
        "@inertiajs/react": "^3.2",
        "@inertiajs/svelte": "^3.0",
        "@inertiajs/vue3": "^3.2",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.9",
        "@types/react": "^19.0",
        "jsdom": "^29.1.1",
        "react": "^19.0",
        "svelte": "^5.0",
        "tsup": "^8.3",
        "typescript": "^5.7",
        "vite": "^8.0",
        "vite-plugin-pwa": "^1.0",
        "vitest": "^4.1",
        "vue": "^3.0"
    },
    "engines": {
        "node": ">=20.19"
    }
}
